# EditorConfig file: http://EditorConfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{d,h,hpp,c,cpp,cxx,cs,hs,java,kt,py,rs,sol,sdl}]
indent_size = 4

[{dub.selections.json,Makefile,go.mod,go.sum,*.go,.gitmodules}]
indent_style = tab
indent_size = 4

[{CMakeLists.txt,*.cmake}]
indent_size = 2
indent_style = space

# Disable indent checking for prettyprint.d - contains multiline string literals
# with intentional 2-space indentation for expected test output
[libs/core-cli/src/sparkles/core_cli/prettyprint.d]
indent_size = unset

# Test data files contain exact byte sequences — no trailing newline
[libs/core-cli/test/data/**]
charset = unset
insert_final_newline = unset

# Disable indent checking for markdown - code blocks may have intentional
# spacing for visual output examples
[*.md]
indent_size = unset

# Also disable charset checking for markdown files in `docs/` as they can
# contain ```ansi code blocks with raw ANSI escape codes (non-printable chars)
[docs/**.md]
charset = unset

# The Make deep-dive embeds real Makefile recipes in fenced code blocks, and
# Make requires literal tabs — so disable indent-style checking for that file.
[docs/research/monorepo-tooling/make/index.md]
indent_style = unset

# Grounding snapshots preserve upstream/manual indentation rather than project style.
[docs/research/application-packaging/grounding/*]
indent_size = unset
