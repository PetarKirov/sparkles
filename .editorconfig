# EditorConfig file: http://EditorConfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{d,h,hpp,c,cpp,cxx,cs,hs,java,kt,py,rs,sol,sdl}]
indent_size = 4

[{dub.selections.json,Makefile,go.mod,go.sum,*.go,.gitmodules}]
indent_style = tab
indent_size = 4

[{CMakeLists.txt,*.cmake}]
indent_size = 2
indent_style = space

# Disable indent checking for prettyprint.d - contains multiline string literals
# with intentional 2-space indentation for expected test output
[libs/core-cli/src/sparkles/core_cli/prettyprint.d]
indent_size = unset

# Disable indent checking for files with intentional non-multiple-of-4 alignment:
# scrypt.d has a wire-format diagram in a DDoc fenced code block, while
# ssh_ed25519.d and secret.d align array-literal elements under the row above.
[libs/age/src/sparkles/age/recipients/scrypt.d]
indent_size = unset

[libs/age/src/sparkles/age/recipients/ssh_ed25519.d]
indent_size = unset

[libs/crypto/src/sparkles/crypto/secret.d]
indent_size = unset

# Test data files contain exact byte sequences — no trailing newline
[libs/core-cli/test/data/**]
insert_final_newline = unset

# age testkit conformance vectors are byte-exact fixtures (some intentionally
# contain trailing whitespace, CR bytes, or specific line endings) — disable
# every normalization check on them.
[libs/age/tests/testkit/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# Disable indent checking for markdown - code blocks may have intentional
# spacing for visual output examples
[*.md]
indent_size = unset
