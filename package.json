{
  "name": "sparkles-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "bash docs/scripts/build-wasm.sh",
    "build:twoslash-showcase": "bash docs/scripts/build-twoslash-showcase.sh",
    "docs:dev": "npm run build:wasm && npm run build:twoslash-showcase && vitepress dev docs --host",
    "docs:build": "npm run build:wasm && npm run build:twoslash-showcase && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "dockview-vue": "^7.0.2",
    "mermaid": "^11.15.0",
    "shiki": "^2.5.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-mermaid": "^2.0.17",
    "wrangler": "^4.63.0"
  }
}
