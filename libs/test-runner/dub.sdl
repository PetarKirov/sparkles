name "test-runner"
description "General-purpose unittest runner with CTFE, betterC, wasm, and benchmark support"
authors "Petar Kirov"
copyright "Copyright © 2026, Petar Kirov"
license "BSL-1.0"

targetPath "build"

dflags "-preview=in" "-preview=dip1000"

// The registration shim: only `discovery` (compile-time reflection over the
// tested package's modules) and `register` (the druntime hook + a thin
// `extern(C)` seam) compile into each consumer's test binary. The heavy
// machinery lives in the prebuilt `sparkles:test-runner-impl` library, so a
// consumer's `dub test` stays close to a vanilla build — an external project
// pulls this package as one dependency and gets both automatically.
//
// In-monorepo `base`/`core-cli` cannot depend on this package (dub rejects the
// resulting cycle: impl → base); their `configuration "unittest"` instead
// source-includes both the shim and the impl:
//
//     sourcePaths "../test-runner/src" "../test-runner-impl/src"
//     importPaths "../test-runner/src" "../test-runner-impl/src"
//
// Every other in-monorepo consumer depends on this package like an external
// one (`dependency "sparkles:test-runner" path="../.."`).
dependency "sparkles:test-runner-impl" path="../.."

targetType "sourceLibrary"

configuration "library" {
    targetType "sourceLibrary"
}

configuration "unittest" {
    // The shim's own tests (discovery) run through the linked impl library.
    targetType "library"

    dflags "-checkaction=context" "-allinst"
    dflags "-defaultlib=libphobos2.so" "-L-fuse-ld=gold" platform="linux-dmd"
    dflags "--link-defaultlib-shared" "--linker=gold" platform="linux-ldc"
    lflags "--export-dynamic" platform="linux-ldc"
}
